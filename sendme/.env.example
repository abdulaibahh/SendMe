# SendMe root environment example.
# Copy values into environment-specific files only. Never commit real secrets.

# Supabase project metadata for local setup and server-side tooling.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Do not expose this in the mobile app.
SUPABASE_SERVICE_ROLE_KEY=

# Firebase project metadata.
FIREBASE_PROJECT_ID=
FIREBASE_ANDROID_APP_ID=

# EAS / Play release metadata.
EAS_PROJECT_ID=
GOOGLE_PLAY_PACKAGE_NAME=com.sendme.sl
